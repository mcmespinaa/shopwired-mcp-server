# ShopWired API Credentials
# Get these from your ShopWired admin: Your Account → API & Webhooks
SHOPWIRED_API_KEY=your_api_key_here
SHOPWIRED_API_SECRET=your_api_secret_here

# Optional: Override the base URL (default: https://api.ecommerceapi.uk/v1)
# SHOPWIRED_API_BASE_URL=https://api.ecommerceapi.uk/v1

# Optional: Rate limit settings (defaults match ShopWired's leaky bucket)
# SHOPWIRED_RATE_LIMIT_BURST=40
# SHOPWIRED_RATE_LIMIT_RATE=2.0
